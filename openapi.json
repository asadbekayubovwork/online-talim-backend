  "info": {
    "title": "Online Ta'lim API",
    "description": "Videokurslar platformasi backend API",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "RegisterDto": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "example": "ali_valiyev",
            "description": "Faqat harf, raqam va _"
          },
          "password": {
            "type": "string",
            "example": "StrongPass123",
            "minLength": 8
          },
          "email": {
            "type": "string",
            "example": "student@example.com"
          },
          "firstName": {
            "type": "string",
            "example": "Ali"
          },
          "lastName": {
            "type": "string",
            "example": "Valiyev"
          },
          "city": {
            "type": "string",
            "example": "Toshkent"
          },
          "country": {
            "type": "string",
            "example": "uz",
            "description": "Davlat kodi"
          },
          "birthDay": {
            "type": "number",
            "example": 15,
            "minimum": 1,
            "maximum": 31
          },
          "birthMonth": {
            "type": "number",
            "example": 6,
            "minimum": 1,
            "maximum": 12
          },
          "birthYear": {
            "type": "number",
            "example": 2000,
            "minimum": 1940
          },
          "phone": {
            "type": "string",
            "example": "+998901234567"
          },
          "universityId": {
            "type": "string",
            "description": "Universitet ID (Hanafiy fiqh fakulteti talabalari uchun)"
          },
          "whatsapp": {
            "type": "string",
            "example": "+998901234567"
          },
          "nationality": {
            "type": "string",
            "example": "O'zbekiston",
            "description": "Fuqarolik"
          }
        },
        "required": [
          "username",
          "password",
          "email",
          "firstName",
          "lastName",
          "birthDay",
          "birthMonth",
          "birthYear",
          "nationality"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "example": "ali_valiyev"
          },
          "password": {
            "type": "string",
            "example": "StrongPass123"
          }
        },
        "required": [
          "username",
          "password"
        ]
      },
      "RefreshDto": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string"
          }
        },
        "required": [
          "refreshToken"
        ]
      },
      "CreateCourseDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "JavaScript noldan"
          },
          "description": {
            "type": "string",
            "example": "Ushbu kursda JavaScript asoslarini o'rganasiz..."
          },
          "thumbnail": {
            "type": "string",
            "example": "https://cdn.example.com/thumb.jpg"
          },
          "price": {
            "type": "number",
            "example": 199000,
            "description": "Narx (so'mda). 0 = bepul"
          },
          "level": {
            "type": "string",
            "enum": [
              "BEGINNER",
              "INTERMEDIATE",
              "ADVANCED"
            ],
            "default": "BEGINNER"
          },
          "categoryId": {
            "type": "string",
            "description": "Kategoriya ID"
          },
          "teacherId": {
            "type": "string",
            "description": "O'qituvchi (User) ID. Berilmasa, kursni yaratgan admin biriktiriladi."
          }
        },
        "required": [
          "title",
          "description"
        ]
      },
      "UpdateCourseDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "JavaScript noldan"
          },
          "description": {
            "type": "string",
            "example": "Ushbu kursda JavaScript asoslarini o'rganasiz..."
          },
          "thumbnail": {
            "type": "string",
            "example": "https://cdn.example.com/thumb.jpg"
          },
          "price": {
            "type": "number",
            "example": 199000,
            "description": "Narx (so'mda). 0 = bepul"
          },
          "level": {
            "type": "string",
            "enum": [
              "BEGINNER",
              "INTERMEDIATE",
              "ADVANCED"
            ],
            "default": "BEGINNER"
          },
          "categoryId": {
            "type": "string",
            "description": "Kategoriya ID"
          },
          "teacherId": {
            "type": "string",
            "description": "O'qituvchi (User) ID. Berilmasa, kursni yaratgan admin biriktiriladi."
          },
          "isPublished": {
            "type": "boolean",
            "description": "Kursni e'lon qilish"
          }
        }
      },
      "CreateLessonDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Kirish darsi"
          },
          "description": {
            "type": "string",
            "example": "Ushbu darsda kursning umumiy tuzilishi..."
          },
          "videoUrl": {
            "type": "string",
            "example": "https://www.youtube.com/watch?v=xxxx",
            "description": "Video havolasi (URL)"
          },
          "duration": {
            "type": "number",
            "example": 600,
            "description": "Davomiyligi (sekundlarda)"
          },
          "order": {
            "type": "number",
            "example": 1,
            "description": "Darslar tartibi"
          },
          "isPreview": {
            "type": "boolean",
            "example": false,
            "description": "Bepul ko'rish (ro'yxatdan o'tmaganlar uchun ham ochiq)"
          }
        },
        "required": [
          "title"
        ]
      },
      "UpdateLessonDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Kirish darsi"
          },
          "description": {
            "type": "string",
            "example": "Ushbu darsda kursning umumiy tuzilishi..."
          },
          "videoUrl": {
            "type": "string",
            "example": "https://www.youtube.com/watch?v=xxxx",
            "description": "Video havolasi (URL)"
          },
          "duration": {
            "type": "number",
            "example": 600,
            "description": "Davomiyligi (sekundlarda)"
          },
          "order": {
            "type": "number",
            "example": 1,
            "description": "Darslar tartibi"
          },
          "isPreview": {
            "type": "boolean",
            "example": false,
            "description": "Bepul ko'rish (ro'yxatdan o'tmaganlar uchun ham ochiq)"
          }
        }
      }
    }
  }
}