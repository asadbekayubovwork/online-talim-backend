// Prisma schema — Online Ta'lim platformasi
// Hujjat: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentProvider {
  CLICK
  PAYME
  STRIPE
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  email        String   @unique
  password     String
  firstName    String
  lastName     String
  role         Role     @default(STUDENT)
  avatarUrl    String?
  // Profil ma'lumotlari (register formasidan)
  city         String?
  country      String?
  birthDate    DateTime?
  phone        String?
  universityId String?
  whatsapp     String?
  nationality  String?
  isActive     Boolean  @default(true)
  refreshToken String? // hashlangan refresh token
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // O'qituvchi sifatida yaratgan kurslari
  taughtCourses Course[]     @relation("CourseTeacher")
  enrollments   Enrollment[]
  progress      Progress[]
  payments      Payment[]
  reviews       Review[]

  @@map("users")
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  courses Course[]

  @@map("categories")
}

model Course {
  id          String      @id @default(uuid())
  title       String
  slug        String      @unique
  description String
  thumbnail   String?
  price       Int         @default(0) // tiyin/so'mda, butun son
  level       CourseLevel @default(BEGINNER)
  isPublished Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  teacherId String
  teacher   User   @relation("CourseTeacher", fields: [teacherId], references: [id])

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  lessons     Lesson[]
  enrollments Enrollment[]
  payments    Payment[]
  reviews     Review[]

  @@index([teacherId])
  @@index([categoryId])
  @@map("courses")
}

model Lesson {
  id          String   @id @default(uuid())
  title       String
  description String?
  // Video havolasi (URL) — YouTube/Vimeo/tayyor manzil
  videoUrl    String?
  // Video provayder ID (kelajakda Mux asset/playback ID yoki S3 kaliti uchun)
  videoAssetId String?
  duration    Int      @default(0) // sekundlarda
  order       Int      @default(0)
  isPreview   Boolean  @default(false) // ro'yxatdan o'tmaganlar uchun bepul ko'rish
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  progress Progress[]

  @@index([courseId])
  @@map("lessons")
}

model Enrollment {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
  @@map("enrollments")
}

model Progress {
  id             String   @id @default(uuid())
  userId         String
  lessonId       String
  completed      Boolean  @default(false)
  watchedSeconds Int      @default(0)
  updatedAt      DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("progress")
}

model Payment {
  id            String          @id @default(uuid())
  userId        String
  courseId      String
  amount        Int
  status        PaymentStatus   @default(PENDING)
  provider      PaymentProvider
  transactionId String? // provayder tomonidan qaytarilgan ID
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@index([userId])
  @@index([courseId])
  @@map("payments")
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  rating    Int // 1-5
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
  @@map("reviews")
}
